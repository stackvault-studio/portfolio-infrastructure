# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy to .env.dev, .env.staging, or .env.prod and fill values
# DO NOT commit .env files to git - they contain sensitive config!
# Secrets (DB_*, SUPABASE_*) are loaded from OCI Vault by load-env.sh
# =============================================================================

# Environment (dev|staging|prod|local)
ENVIRONMENT=dev

# Docker Images and Tags
BACKEND_IMAGE=ossemaabd95/stackvault
BACKEND_TAG=dev
FRONT_IMAGE=ossemaabd95/stackvault
FRONT_TAG=dev

# Frontend Port
FRONT_PORT=8080