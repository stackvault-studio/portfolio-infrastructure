# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy to .env.dev, .env.staging, or .env.prod and fill values
# DO NOT commit .env files to git - they contain sensitive config!
# Secrets (DB_*, SUPABASE_*) are loaded from OCI Vault by load-secrets.sh
# =============================================================================

# Environment (dev|staging|prod)
ENVIRONMENT=dev

# Docker Image Tags
BACKEND_TAG=dev
FRONT_TAG=dev

# Frontend Port
FRONT_PORT=8080